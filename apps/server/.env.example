# ===== CONFIGURAÇÕES GERAIS =====
NODE_ENV="development"
PORT=3005
CORS_ORIGIN="http://localhost:3010"
SYSTEM_NAME="ErpSys - Sistema de Comunicação Visual"
SYSTEM_VERSION="1.0.0"

# ===== BANCO DE DADOS =====
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/erp_system"

# ===== AUTENTICAÇÃO =====
JWT_SECRET="sua-chave-secreta-super-segura-mude-em-producao"
JWT_EXPIRES_IN="7d"

# ===== IA - SISTEMA FINANCEIRO =====
# OpenAI Configuration
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Claude Configuration  
ANTHROPIC_API_KEY="sk-ant-your-claude-api-key-here"

# AI Service Configuration
AI_DEFAULT_PROVIDER="openai"  # openai | claude
AI_FALLBACK_PROVIDER="claude"  # openai | claude
AI_MAX_RETRIES=2
AI_TIMEOUT=30000

# ===== LOGS =====
LOG_LEVEL="debug"

# ===== REDIS (CACHE) - OPCIONAL =====
# REDIS_URL="redis://localhost:6379"

# ===== PERFORMANCE - OPCIONAL =====
# ENABLE_QUERY_LOGGING=false
# ENABLE_TELEMETRY=false