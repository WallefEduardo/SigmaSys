{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"downlevelIteration": true,
		"baseUrl": "./",
		"paths": {
			"@/*": ["./src/*"],
			"prisma": ["node_modules/prisma"]
		},
		"outDir": "./dist",
		"types": ["node"],
		"composite": true,
		"jsx": "react-jsx",
		"incremental": true,
		"tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
	}
}
