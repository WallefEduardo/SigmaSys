{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch --clear-screen=false --ignore=\"dist/**\" --ignore=\"node_modules/**\" src/index.ts",
		"start": "node dist/index.js",
		"seed:categories": "tsx src/scripts/seed-categories.ts",
		"seed:categories:clear": "tsx src/scripts/seed-categories.ts --clear"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.61.0",
		"@fastify/cors": "^11.0.1",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/auto-instrumentations-node": "^0.62.1",
		"@opentelemetry/exporter-prometheus": "^0.203.0",
		"@opentelemetry/sdk-node": "^0.203.0",
		"@prisma/client": "^6.13.0",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@repo/database": "workspace:*",
		"@trpc/client": "^11.4.2",
		"@trpc/server": "^11.4.2",
		"@types/bull": "^4.10.4",
		"bcryptjs": "^3.0.2",
		"bull": "^4.16.5",
		"bullmq": "^5.58.0",
		"date-fns": "^4.1.0",
		"decimal.js": "^10.6.0",
		"dotenv": "^17.2.1",
		"express-rate-limit": "^8.0.1",
		"fastify": "^5.3.3",
		"ioredis": "^5.7.0",
		"jsonwebtoken": "^9.0.2",
		"mathjs": "^14.6.0",
		"openai": "^5.20.0",
		"pino": "^9.9.0",
		"pino-pretty": "^13.1.1",
		"zod": "^4.0.2",
		"zod-to-json-schema": "^3.24.6"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/mathjs": "^9.4.2",
		"@types/node": "^22.13.11",
		"prisma": "^6.13.0",
		"tsdown": "^0.12.9",
		"tsx": "^4.19.2",
		"typescript": "^5.8.2"
	}
}
