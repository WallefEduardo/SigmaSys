{
	"name": "my-better-t-app",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @repo/database db:push",
		"db:studio": "turbo -F @repo/database db:studio",
		"db:generate": "turbo -F @repo/database db:generate",
		"db:migrate": "turbo -F @repo/database db:migrate",
		"db:seed": "turbo -F @repo/database db:seed",
		"db:start": "turbo -F @repo/database db:start",
		"db:watch": "turbo -F @repo/database db:watch",
		"db:stop": "turbo -F @repo/database db:stop",
		"db:down": "turbo -F @repo/database db:down"
	},
	"dependencies": {
		"date-fns": "^4.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"turbo": "^2.5.4"
	},
	"packageManager": "pnpm@10.14.0"
}
